# ====================================================
# KEEP ME POSTED — Environment Variables Template
# Copy to .env.local and fill in real values
# NEVER commit .env.local to version control
# ====================================================

# ------------------------------------------------
# AI / LLM
# ------------------------------------------------

# Anthropic Claude API (recommended for analysis engine)
VITE_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (alternative LLM provider)
VITE_OPENAI_API_KEY=sk-...

# ------------------------------------------------
# News Data Sources
# ------------------------------------------------

# NewsAPI.org — general news aggregation
VITE_NEWSAPI_KEY=...

# GNews API — additional news source
VITE_GNEWS_API_KEY=...

# ------------------------------------------------
# Social / X (Twitter)
# ------------------------------------------------

# X (Twitter) API v2 Bearer Token
VITE_TWITTER_BEARER_TOKEN=...

# ------------------------------------------------
# Weather
# ------------------------------------------------

# Bureau of Meteorology API (or WeatherAPI.com for structured data)
VITE_WEATHER_API_KEY=...

# OpenWeatherMap (alternative)
VITE_OPENWEATHER_API_KEY=...

# ------------------------------------------------
# Commodity / Market Data
# ------------------------------------------------

# MLA Livestock Data — register at mla.com.au/data
VITE_MLA_API_KEY=...

# ABARES data endpoint
VITE_ABARES_ENDPOINT=https://www.agriculture.gov.au/abares/api

# ------------------------------------------------
# Database (Supabase recommended)
# ------------------------------------------------

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=...

# ------------------------------------------------
# Backend API (if running separate Node/Python server)
# ------------------------------------------------

VITE_API_BASE_URL=http://localhost:3001/api

# ------------------------------------------------
# App Config
# ------------------------------------------------

# Refresh interval in milliseconds (default: 300000 = 5 minutes)
VITE_REFRESH_INTERVAL=300000

# Enable mock data fallback (true = use mockData.js when APIs unavailable)
VITE_USE_MOCK_DATA=true
