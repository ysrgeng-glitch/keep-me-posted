# ====================================================
# KEEP ME POSTED — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ====================================================

# ─── Frontend (Vite — must be prefixed VITE_) ───────────────────────────────

# Supabase project URL  (Settings → API → Project URL)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anon public key  (Settings → API → anon key)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Edge Function secrets (set in Supabase dashboard) ──────────────────────
# Dashboard → Settings → Edge Functions → Secrets
# These are NOT VITE_ prefixed — they only exist server-side.

# Google Gemini API key — FREE, no credit card needed
# Get it at: https://aistudio.google.com/app/apikey  (takes 30 seconds)
# Free tier: 1,500 requests/day — more than enough for hourly runs
GEMINI_API_KEY=AIzaSy...

# Supabase service role key  (Settings → API → service_role key)
# Used by the Edge Function to write articles to the DB
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# NewsAPI.org key — OPTIONAL, adds extra news coverage  (newsapi.org, free tier)
NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
